{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "strict":           true,
    "esModuleInterop":  true,
    "outDir":           "dist",
    "declaration":      true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck":     true,
    "types": ["node", "hardhat"]
  },
  "include": ["hardhat.config.ts", "test/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "artifacts", "cache", "dist"]
}
