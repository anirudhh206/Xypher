# ─────────────────────────────────────────────────────────────────────────────
# ConfidentialGuard Protocol — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Deployer wallet private key (no 0x prefix required by Hardhat)
DEPLOYER_PRIVATE_KEY=

# RPC endpoints
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Block explorer API keys
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Workflow address (set after CRE workflow deployment)
WORKFLOW_ADDRESS=

# Chainlink CCIP router addresses
SEPOLIA_CCIP_ROUTER=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
BASE_SEPOLIA_CCIP_ROUTER=0xD3b06cEbF099CE7DA4AcCf578aaebFDBd6e88a93

# Chainlink ETH/USD Price Feed addresses
SEPOLIA_ETH_USD_FEED=0x694AA1769357215DE4FAC081bf1f309aDC325306
BASE_SEPOLIA_ETH_USD_FEED=0x4aDC67696bA383F43DD60A9e78F2C97Fbbfc7cb1

# Gas reporting
REPORT_GAS=false
